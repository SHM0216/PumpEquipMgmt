// ==========================================================
// 빗물펌프장 시설물 관리 시스템 (RPMS) — Prisma Schema
// ==========================================================
// 개발: SQLite (file:./prisma/dev.db)
// 운영: PostgreSQL (DATABASE_URL 환경변수로 전환)
//
// 주요 엔터티:
//   Facility     — 펌프장 (월성1/2/3, 대명유수지, 월성공통)
//   Equipment    — 설비 (호기 단위 추적, 선택적)
//   Part         — 부품·작업 단위 유지관리 (핵심 단위) ★
//   Maintenance  — 유지보수 계약 이력
//   Inspection   — 점검 기록
//   PmMaster     — 예방정비 주기 마스터
//   Attachment   — 첨부파일(도면·사진·보고서)
//   User         — 사용자 (Phase 8)
//   AuditLog     — 감사 로그 (Phase 8)
//
// 계층:
//   Facility → Part (부품/작업 단위) → Maintenance
//            └ Equipment (호기 단위, optional)
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ──────────────────────────────────────────────────────────
// 시설물 (펌프장 + 유수지 + 공통)
// ──────────────────────────────────────────────────────────
model Facility {
  id            String    @id                    // ws1, ws2, ws3, myu, common
  name          String
  kind          String    @default("pump")       // pump/reservoir/common
  installYear   Int?
  installMonth  Int?
  location      String?
  power         String?
  pumpCount     Int?
  pumpCapacity  String?
  pumpSpec      String?
  screen        String?
  note          String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  equipment     Equipment[]
  maintenance   Maintenance[]
  inspections   Inspection[]

  @@index([name])
}

// ──────────────────────────────────────────────────────────
// 설비 (호기 단위 - 선택적)
// ──────────────────────────────────────────────────────────
model Equipment {
  id             String    @id @default(cuid())
  facilityId     String
  category       String
  subcategory    String
  name           String
  model          String?
  vendor         String?
  installDate    DateTime?
  lifeYears      Int?
  lastMaintDate  DateTime?
  status         String    @default("good")
  remark         String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  facility       Facility       @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  parts          Part[]
  maintenance    Maintenance[]
  inspections    Inspection[]

  @@index([facilityId, category])
  @@index([status])
}

// ──────────────────────────────────────────────────────────
// 부품 / 작업 단위 — 유지관리의 실제 최소 단위 ★ 핵심
// ──────────────────────────────────────────────────────────
// 업로드된 『월성펌프장_펌프장별_부품_유지보수이력.xlsx』의
// "펌프장 × 설비 × 부품·작업" 3계층 구조를 반영.
//
// 일부 부품은 특정 시설(월성1·2·3)이 아닌 "월성공통", "대명유수지"
// 처럼 가상 시설로 분류되므로 facilityCode를 자유 문자열로 둠.
// ──────────────────────────────────────────────────────────
model Part {
  id              String    @id @default(cuid())
  facilityCode    String                            // ws1/ws2/ws3/ws-daemyeong/ws-common
  facilityLabel   String                            // 월성1/월성2/월성3/대명유수지/월성공통
  equipmentGroup  String                            // 펌프/제진기/전기/기계/통신/기타
  equipmentId     String?                           // 호기 단위 Equipment와 매핑 (선택)
  partName        String                            // "전동펌프 6호기", "그랜드패킹" 등
  spec            String?                           // 규격·수량 (예: "600㎥/min × 1,750HP")

  // 시행 이력 (자유 텍스트)
  history         String?                           // "• 2022: 오버홀 공사 [#42]"

  // 시행 주기
  cycle           String?                           // "3~5년", "연 1회"
  cycleMonths     Int?                              // 계산용 (예: 36)

  // 차기 시기
  nextTime        String?                           // "2027년 (★누적지연)"
  nextYear        Int?                              // 정렬·필터용 (예: 2027)

  // 상태
  status          String    @default("normal")      // overdue/normal/long/new/done
  statusLabel     String?                           // 원문 ("정상주기", "★누적지연" 등)
  overdue         Boolean   @default(false)         // ★ 플래그
  isNew           Boolean   @default(false)         // ◆ 플래그 (신설)

  note            String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  equipment       Equipment?    @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  events          PartEvent[]
  maintenance     Maintenance[]

  @@index([facilityCode])
  @@index([equipmentGroup])
  @@index([status])
  @@index([nextYear])
  @@index([equipmentId])
}

// ──────────────────────────────────────────────────────────
// 부품 연도별 이벤트 — 2020~2030 타임라인 매트릭스용
// 시트 ②『연도별 타임라인』에 대응
//   ● = 시행완료 (done)
//   ◐ = 시행 예상 (planned)
//   ★ = 누적 지연 (overdue)
//   ◆ = 신설 (new)
// ──────────────────────────────────────────────────────────
model PartEvent {
  id              String    @id @default(cuid())
  partId          String
  year            Int                               // 2020~2030 등
  eventType       String                            // done/planned/overdue/new
  symbol          String                            // ●/◐/★/◆ (UI 표시용)
  note            String?
  maintenanceId   String?                           // 연계 계약 (선택)

  createdAt       DateTime  @default(now())

  part            Part         @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([partId, year, eventType])
  @@index([year])
}

// ──────────────────────────────────────────────────────────
// 유지보수 이력 (계약 단위)
// ──────────────────────────────────────────────────────────
model Maintenance {
  id             String    @id @default(cuid())
  date           DateTime
  year           Int
  facilityId     String
  equipmentId    String?
  partId         String?
  category       String
  subcategory    String
  name           String
  vendor         String?
  amount         BigInt
  contractType   String
  contractNo     String?
  serialNo       Int?
  description    String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  facility       Facility    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipment      Equipment?  @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  part           Part?       @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([year])
  @@index([facilityId, year])
  @@index([category, subcategory])
  @@index([partId])
}

// ──────────────────────────────────────────────────────────
// 점검 기록
// ──────────────────────────────────────────────────────────
model Inspection {
  id             String    @id @default(cuid())
  date           DateTime
  facilityId     String
  equipmentId    String?
  partId         String?
  inspType       String
  target         String
  result         String
  memo           String?
  inspector      String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  facility       Facility    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipment      Equipment?  @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@index([facilityId, date])
  @@index([result])
}

// ──────────────────────────────────────────────────────────
// 예방정비 주기 마스터
// ──────────────────────────────────────────────────────────
model PmMaster {
  id             String    @id @default(cuid())
  category       String
  subcategory    String
  item           String
  cycleMonths    Int
  basis          String?
  active         Boolean   @default(true)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([category, subcategory, item])
}

// ──────────────────────────────────────────────────────────
// 첨부파일 / 사용자 / 감사로그
// ──────────────────────────────────────────────────────────
model Attachment {
  id             String    @id @default(cuid())
  refType        String
  refId          String
  docCategory    String
  filename       String
  filepath       String
  mimeType       String?
  size           Int?

  uploadedAt     DateTime  @default(now())
  uploadedBy     String?

  @@index([refType, refId])
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  name           String
  role           String    @default("VIEWER")
  department     String?
  email          String?
  active         Boolean   @default(true)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AuditLog {
  id             String    @id @default(cuid())
  userId         String?
  action         String
  target         String
  targetId       String?
  changes        String?
  ip             String?

  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
}
