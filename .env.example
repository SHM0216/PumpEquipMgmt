# ==========================================================
# RPMS 환경변수 예시 — 실제 사용 시 .env.local 로 복사
# ==========================================================

# 데이터베이스
# - 개발(SQLite): file:./prisma/dev.db
# - 운영(PostgreSQL): postgresql://user:password@host:5432/rpms
DATABASE_URL="file:./prisma/dev.db"

# 업로드 경로 (도면·사진·보고서)
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB=50

# 인증 (Phase 8부터 사용)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=여기에-openssl-rand-base64-32-결과값-입력
# GOV_SSO_CLIENT_ID=
# GOV_SSO_CLIENT_SECRET=

# 알림 (Phase 7부터 사용)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ALERT_FROM_EMAIL=rpms@example.go.kr

# 기타
NEXT_PUBLIC_APP_NAME="빗물펌프장 시설물 관리 시스템"
NEXT_PUBLIC_ORG_NAME="도시관리본부 배수운영과"
